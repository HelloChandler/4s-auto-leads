# 环境变量配置模板
# 复制此文件为.env并填写真实配置

# 大模型API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：其他大模型配置
# DOUBAO_API_KEY=your_doubao_api_key_here
# QIANWEN_API_KEY=your_qianwen_api_key_here

# 数据库配置（默认SQLite，无需修改）
DATABASE_URL=sqlite:///data/leads.db

# 代理配置（可选，如果使用代理池）
# PROXY_POOL_URL=http://your-proxy-pool:5010/get
# PROXY_USERNAME=your_proxy_username
# PROXY_PASSWORD=your_proxy_password

# OpenClaw配置
OPENCLAW_API_KEY=your_openclaw_api_key_here
OPENCLAW_BASE_URL=http://localhost:8080

# 短信/电话服务配置（可选）
# SMS_API_KEY=your_sms_service_api_key
# CALL_API_KEY=your_call_service_api_key

# 其他配置
DEBUG=false
LOG_LEVEL=INFO